# Build stage
FROM golang:1.23 AS builder

WORKDIR /app

# Set Go proxy for faster downloads in China
ENV GOPROXY=https://goproxy.cn,direct

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -installsuffix cgo -o k8s-manager ./cmd/server

# Runtime stage
FROM centos

WORKDIR /app

# Copy binary
COPY --from=builder /app/k8s-manager .

EXPOSE 8080

ENTRYPOINT ["./k8s-manager"]
CMD ["--config=/app/conf/config.yaml"]
